    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.6.2",
    "auto-launch": "^5.0.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
